{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "$comment": "Add your installed wezterm-types path to workspace.library in your editor or local override config.",
  "runtime": {
    "version": "Lua 5.4",
    "path": ["plugin/?.lua"]
  },
  "workspace": {
    "checkThirdParty": true,
    "useGitIgnore": true,
    "library": ["${3rd}/luv/library"]
  },
  "diagnostics": {
    "libraryFiles": "Opened"
  },
  "hint": {
    "enable": true,
    "paramType": true,
    "setType": true
  }
}
